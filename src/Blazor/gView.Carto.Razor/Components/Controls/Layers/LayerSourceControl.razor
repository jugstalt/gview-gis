@using System.Text
@using gView.Framework.IO

@GvUtilities.InfoText("All values here are for information only. You can not change this values on this page.")

@if(_dataset is not null)
{
    <GvCard Title="Dataset">
        <GvCardContent>
            @if(_dataset is IFeatureDataset && Map?.Datasets.Any() == true)
            {
                <MudSelect T="IDataset" Label="Dataset Type"
                           @bind-Value="_dataset">
                    @foreach(var dataset in Map.Datasets.Where(d => d is IFeatureDataset))
                    {
                        <MudSelectItem Value="dataset">@dataset.GetType().ToString()</MudSelectItem>
                    }
                </MudSelect>
            } else {
                <MudTextField Label="Dataset Type" ReadOnly="true"
                              Value="_dataset.GetType().ToString()" />
            }
            <MudTextField Label="Dataset Name" ReadOnly="true"
                          Value="_dataset.DatasetName" />
            <MudTextField Label="Connection String" ReadOnly="true" Lines="5"
                          Value="PrepareConnectionString(_dataset.ConnectionString)" />
        </GvCardContent>
    </GvCard>
}


<GvCard Title="Class">
    <GvCardContent>
        @{
            var fcNames = DatasetClassNames().GetAwaiter().GetResult(); 
        }
        @if (_dataset is IFeatureDataset && fcNames?.Any() == true)
        {
            <MudSelect Label="Name" MultiSelection="false" T="String"
                       @bind-Value="_clsName">
                @foreach (var fcName in fcNames)
                {
                    <MudSelectItem Value="fcName">
                        @fcName
                    </MudSelectItem>
                }
            </MudSelect>
            @if((_clsName != Layer?.Title
                || Map?.Datasets.IndexOf(_dataset) != Layer?.DatasetID)
                && fcNames.Contains(_clsName))
            {
                    <MudButton Color="Color.Secondary" 
                               Variant="Variant.Filled"
                               OnClick="OnClassSelectionCanceled">
                        Cancel
                    </MudButton>
                    <MudButton Color="Color.Primary" 
                               Variant="Variant.Filled"
                               OnClick="OnChangeClassName">
                        Change
                    </MudButton>
            }
        } 
        else 
        {
            <MudTextField Label="Name" ReadOnly="true" 
                          Value="@(Layer?.Title ?? "")" />
        }
    </GvCardContent>
</GvCard>


@if(Layer is not null)
{
    <GvCard Title="Layer">
        <GvCardContent>
            <MudNumericField Label="Layer ID" Value="Layer.ID" ReadOnly="true" />
        </GvCardContent>
    </GvCard>
}

@code {
    [Parameter] public IMap? Map { get; set; }
    [Parameter] public ILayer? Layer { get; set; }

    private IDataset? _dataset;
    private string _clsName = "";

    async protected override Task OnParametersSetAsync()
    {
        base.OnParametersSet();

        if (Map is not null && Layer is not null)
        {
            _clsName = Layer.Title;

            var datasets = Map.Datasets.ToArray();

            if (Layer.DatasetID >= 0 && Layer.DatasetID < datasets.Length)
            {
                _dataset = datasets[Layer.DatasetID];
            }
        }
    }

    private void OnClassSelectionCanceled()
    {
        if(Layer is null || Map is null) return;

        _clsName = Layer.Title;
        _dataset = Map.Datasets.ToArray()[Layer.DatasetID];
    }

    async private Task OnChangeClassName()
    {
        if(_dataset is null || Map is null)
        {
            return;
        }

        if (Layer is gView.Framework.Data.Layer layer)
        {
            var oldTitle = layer.Title;
            var oldClass = layer.Class;
            try
            {
                var datasetElement = await _dataset.Element(_clsName);
                if (datasetElement?.Class is not null)
                {
                    layer.Title = _clsName;
                    layer.Class = datasetElement.Class;
                    layer.DatasetID = Map.Datasets.IndexOf(_dataset);
                }
            }
            catch(Exception)
            {
                layer.Title = oldTitle;
                layer.Class = oldClass;

                _clsName = oldTitle;
            }
        }
    }

    async private Task<List<string>> DatasetClassNames()
    {
        if(Layer is null || _dataset is null) return [];

        if (Layer.Class is IFeatureClass layerFc)
        {
            return (await _dataset.Elements())
                .Where(e => e.Class is IFeatureClass fc 
                    && (fc.GeometryType == layerFc.GeometryType || layerFc.GeometryType == GeometryType.Aggregate))
                .Select(e => e.Class.Name)
                .ToList();
        }
        
        return (await _dataset.Elements())
                .Select(e => e.Class.Name)
                .ToList();

    }

    // Hide Password etc
    private string PrepareConnectionString(string str)
    {
        Dictionary<string, string> dic = ConfigTextStream.Extract(str);

        StringBuilder sb = new StringBuilder();
        foreach (string key in dic.Keys)
        {
            if (String.IsNullOrEmpty(dic[key]))
            {
                sb.Append(key);
            }
            else
            {
                switch (key.ToLower())
                {
                    case "password":
                    case "pwd":
                        sb.Append(key + "=*****");
                        break;
                    default:
                        sb.Append(key + "=" + dic[key]);
                        break;
                }
            }
            sb.Append("\r\n");
        }

        return sb.ToString();
    }
}